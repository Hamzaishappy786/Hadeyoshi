{
  "name": "video-editor",
  "version": "1.0.0",
  "description": "Personal desktop video editor",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently --kill-others-on-fail \"npm run backend\" \"npm run frontend\" \"wait-on http-get://localhost:8000/health http-get://localhost:5173 && set NODE_ENV=development&& electron .\"",
    "electron": "electron .",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && python -m uvicorn main:app --port 8000 --reload",
    "build": "cd frontend && npm run build",
    "pack": "electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0"
  }
}
